<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport"
          content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- Use the title from a page's frontmatter if it has one -->
    <title><%= current_page.data.title || "Middleman" %></title>

    <!-- SEO Meta Tags -->
    <meta name="description" content="<%= current_page.data.description || 'Ruby Retreat is a full weekend retreat for people interested in web development to gather and be awesome together.' %>">
    <link rel="canonical" href="<%= current_page.data.url || 'https://retreat.ruby.org.au' %>">

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= current_page.data.url || 'https://retreat.ruby.org.au' %>">
    <meta property="og:title" content="<%= current_page.data.title || 'Ruby Retreat' %>">
    <meta property="og:description" content="<%= current_page.data.description || 'Ruby Retreat is a full weekend retreat for people interested in web development to gather and be awesome together.' %>">
    <meta property="og:image" content="<%= current_page.data.image || 'https://retreat.ruby.org.au/images/social.jpg' %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="628">

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= current_page.data.title || 'Ruby Retreat' %>">
    <meta name="twitter:description" content="<%= current_page.data.description || 'Ruby Retreat is a full weekend retreat for people interested in web development to gather and be awesome together.' %>">
    <meta name="twitter:image" content="<%= current_page.data.image || 'https://retreat.ruby.org.au/images/social.jpg' %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
   <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
   <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%= stylesheet_link_tag "site" %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              emerald: {
                50: '#ecfdf5',
                100: '#d1fae5',
                600: '#059669',
                700: '#047857',
                800: '#065f46'
              }
            }
          }
        }
      }
    </script>
    <%= javascript_include_tag "site" %>
  </head>
  <body class="font-sans">
    <%= yield %>
  </body>
</html>
